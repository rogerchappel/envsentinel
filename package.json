{
  "name": "envsentinel",
  "version": "0.1.0",
  "description": "Local-first environment contract auditor for examples, docs, CI, compose, and code references.",
  "type": "module",
  "bin": {
    "envsentinel": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "env",
    "dotenv",
    "cli",
    "audit",
    "configuration",
    "typescript"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/envsentinel.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/envsentinel/issues"
  },
  "homepage": "https://github.com/rogerchappel/envsentinel#readme"
}
